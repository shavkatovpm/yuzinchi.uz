---
import { getLangFromUrl, useTranslations, pageUrls } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const urls = pageUrls[lang];

const currentYear = new Date().getFullYear();

const footerLinks = {
  company: [
    { name: t('nav.services'), href: urls.services },
    { name: t('nav.articles'), href: urls.articles },
    { name: t('nav.contact'), href: urls.contact },
  ]
};

const socialLinks = [
  {
    name: 'Telegram',
    href: 'https://t.me/yuzinchi_uz',
    icon: `<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>`
  }
];
---

<footer class="border-t border-light/5 bg-dark">
  <div class="container-custom py-12 md:py-16">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href={urls.home} class="flex items-center gap-2 text-xl font-bold text-light">
          <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-dark text-lg font-black text-accent">
            100
          </span>
          <span class="text-accent">Yuzinchi</span>
        </a>
        <p class="mt-4 text-sm text-light/60">
          {t('footer.description')}
        </p>
        <div class="mt-6 flex gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center rounded-lg border border-light/10 text-light/60 transition-colors hover:border-accent hover:text-accent"
              aria-label={link.name}
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" set:html={link.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Links - 2 columns on mobile, separate on desktop -->
      <div class="col-span-1 md:col-span-2 grid grid-cols-2 gap-4 md:grid-cols-2 md:gap-8">
        <!-- Company -->
        <div>
          <h3 class="hidden text-sm font-semibold uppercase tracking-wider text-light md:block">
            {t('footer.company')}
          </h3>
          <ul class="space-y-3 md:mt-4">
            {footerLinks.company.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-light/60 transition-colors hover:text-accent"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <h3 class="hidden text-sm font-semibold uppercase tracking-wider text-light md:block">
            {t('footer.contact')}
          </h3>
          <ul class="space-y-3 md:mt-4">
            <li>
              <a
                href="tel:+998773009928"
                class="text-sm text-light/60 transition-colors hover:text-accent"
              >
                +998 77 300 99 28
              </a>
            </li>
            <li>
              <span class="text-sm text-light/60">
                Toshkent, O'zbekiston
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-light/5 pt-8 sm:flex-row">
      <p class="text-sm text-light/60">
        &copy; {currentYear} Yuzinchi. {t('footer.rights')}.
      </p>
    </div>
  </div>
</footer>
