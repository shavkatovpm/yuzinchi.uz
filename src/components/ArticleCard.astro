---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  category: string;
  readingTime?: number;
  lang: string;
}

const { title, description, pubDate, slug, tags = [], category, readingTime, lang } = Astro.props;
const t = useTranslations(lang as any);

const formattedDate = pubDate.toLocaleDateString(lang === 'uz' ? 'uz-UZ' : 'ru-RU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const articleUrl = lang === 'uz' ? `/uz/maqolalar/${slug}` : `/ru/stati/${slug}`;
const categoryKey = `articles.category.${category.toLowerCase()}` as any;
const categoryLabel = t(categoryKey) || category;
---

<article class="group h-full" itemscope itemtype="https://schema.org/Article">
  <a href={articleUrl} class="flex h-full flex-col rounded-2xl border border-light/5 p-6 transition-all hover:border-accent/20 hover:bg-light/[0.02]">
    <!-- Category & Reading Time -->
    <div class="flex items-center gap-3">
      <span class="rounded-full bg-accent/15 px-3 py-1 text-xs font-semibold text-accent">
        {categoryLabel}
      </span>
      {readingTime && (
        <span class="text-xs text-light/40">
          {readingTime} {t('articles.readingTime')}
        </span>
      )}
      <time class="ml-auto text-xs text-light/40" itemprop="datePublished" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <!-- Title -->
    <h2 class="mt-4 text-xl font-semibold text-light transition-colors group-hover:text-accent" itemprop="headline">
      {title}
    </h2>

    <!-- Description -->
    <p class="mt-2 flex-1 line-clamp-2 text-sm text-light/60" itemprop="description">
      {description}
    </p>

    <!-- Tags + Read More -->
    <div class="mt-4 flex items-center justify-between">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.slice(0, 3).map((tag) => (
            <span class="rounded-full bg-light/5 px-2.5 py-0.5 text-xs text-light/40">
              #{tag}
            </span>
          ))}
        </div>
      )}
      <span class="ml-auto flex items-center gap-1 text-sm font-medium text-accent">
        {t('articles.readMore')}
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </a>
</article>
